# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# data pipeline intermediate files
/data-pipeline/processed/
/data-pipeline/downloads/
/data-pipeline/raw/
/data-pipeline/__pycache__/
/data-pipeline/verify_*.json
/data-pipeline/inspect_*.json
/data-pipeline/inspect_*.py
/data-pipeline/sh_*.json

# mcp server
mcp-server/node_modules/
mcp-server/build/
mcp-server/*.txt

# temp / debug files
temp_*

# claude code memory (global system, not per-project)
memory/

# data backups (timestamped local snapshots)
public/data/*.bak-*

# python venv
.venv/

# typescript
*.tsbuildinfo
next-env.d.ts
